{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-base",
      "description": "Target Windows with the Visual Studio development environment.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug (Strict Galaga)",
      "description": "Target Windows (64-bit) evaluation build. (Debug)",
      "inherits": "windows-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_GRAVITY_BENDER": "OFF"
      }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release (Strict Galaga)",
      "description": "Target Windows (64-bit) evaluation build. (Release)",
      "inherits": "x64-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GRAVITY_BENDER": "OFF"
      }
    },
    {
      "name": "x64-debug-prototype",
      "displayName": "x64 Debug (Gravity Bender)",
      "description": "Target Windows (64-bit) rapid prototyping environment. (Debug)",
      "inherits": "x64-debug",
      "cacheVariables": {
        "BUILD_GRAVITY_BENDER": "ON"
      }
    },
    {
      "name": "x64-release-prototype",
      "displayName": "x64 Release (Gravity Bender)",
      "description": "Target Windows (64-bit) rapid prototyping environment. (Release)",
      "inherits": "x64-release",
      "cacheVariables": {
        "BUILD_GRAVITY_BENDER": "ON"
      }
    },
    {
      "name": "clang-debug",
      "displayName": "clang Debug (Strict Galaga)",
      "description": "Using compilers: C = /usr/bin/clang, CXX = /usr/bin/clang++",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_GRAVITY_BENDER": "OFF"
      }
    },
    {
      "name": "clang-release",
      "displayName": "clang Release (Strict Galaga)",
      "description": "Using compilers: C = /usr/bin/clang, CXX = /usr/bin/clang++",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GRAVITY_BENDER": "OFF"
      }
    },
    {
      "name": "clang-debug-prototype",
      "displayName": "clang Debug (Gravity Bender)",
      "description": "Rapid prototyping environment for clang.",
      "inherits": "clang-debug",
      "cacheVariables": {
        "BUILD_GRAVITY_BENDER": "ON"
      }
    }
  ]
}